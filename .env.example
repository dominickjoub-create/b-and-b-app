# Copy to .env.local for local dev; set the same variables in Vercel for prod.
# The README explains where each value comes from.

# --- Supabase (Project Settings → API) -------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SECRET. Server-only: never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- PayFast (Merchant Dashboard → Settings) -------------------------
# sandbox | live  (sandbox uses sandbox.payfast.co.za, no real money)
PAYFAST_MODE=sandbox
# Sandbox test credentials are shown at https://sandbox.payfast.co.za
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
# Must exactly match the passphrase set in the PayFast dashboard.
PAYFAST_PASSPHRASE=

# --- App -------------------------------------------------------------
# Public URL of the app INCLUDING the /app base path (no trailing slash).
# PayFast return/cancel/notify URLs are built from this, so for local
# webhook testing it must be a publicly reachable URL (e.g. ngrok).
NEXT_PUBLIC_SITE_URL=https://learnersdrive.co.za/app
NEXT_PUBLIC_BASE_PATH=/app
# Course price in Rand — must match what you advertise; the webhook
# rejects payments for any other amount.
COURSE_PRICE_ZAR=299.00
# Object path of the study book inside the private `materials` bucket.
BOOK_PDF_PATH=k50-study-book.pdf
NEXT_PUBLIC_SUPPORT_EMAIL=support@learnersdrive.co.za
